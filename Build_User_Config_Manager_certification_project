def update_setting(settings, new):
    key = str(new[0]).lower()
    value = str(new[1]).lower()

    lower_key_map = {k.lower(): k for k in settings.keys()}

    if key in lower_key_map:
        orig_key = lower_key_map[key] 
        settings[orig_key] = value
        return f"Setting '{orig_key}' updated to '{value}' successfully!"
    else:
        return f"Setting '{key}' does not exist! Cannot update a non-existing setting."


def delete_setting(settings, key):
    key = key.lower()
    lower_key_map = {k.lower(): k for k in settings.keys()}
    if key in lower_key_map:
        orig_key = lower_key_map[key]
        settings.pop(orig_key)
        return f"Setting '{orig_key}' deleted successfully!"
    else:
        return f"Setting not found!"

def view_settings(settings):
    if not settings:
        return "No settings available."
    
    result = "Current User Settings:\n"
    for key, value in settings.items():
        key_c = key.capitalize()
        result += f"{key_c}: {value}\n"
    
    return result

