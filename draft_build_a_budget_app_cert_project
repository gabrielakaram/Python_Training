class Category:
    def __init__(self,name):
        self.name = name
        self.ledger = []

    def deposit(self,amount,description):
        if not description:
            description = ''
        
        add = {'amount': amount, 'description': description}
        self.ledger.append(add)

    def withdraw(self,amount,description):
        if not self.check_funds(amount):
            return False

        else:
            if not description:
                description = ''
        
            remove = {'amount': -amount, 'description': description}
            self.ledger.append(remove)
            return True

    def get_balance(self):
        balance = 0
        for transaction in self.ledger:
            balance += transaction['amount']
        return balance

    def transfer(self, amount, Cat):
        if not self.check_funds(amount):
            return False
        self.withdraw(amount, f'Transfer to {Cat.name}')
        Cat.deposit(amount, f'Transfer from {self.name}')
        return True
    
    def check_funds(self,amount):
        balance = self.get_balance()
        if amount > balance:
            return False
        else:
            return True
    def __str__(self):
        balance=self.get_balance()
        header='*'*((30-len(self.name))//2)
        message = f'{header}{self.name}{header}\n'
        for transaction in self.ledger:     
            cut_description = transaction['description'][:23]
            part = f"{cut_description:<23}{transaction['amount']:>7.2f}"
            message += part + '\n'
        
        message += f'Total: {balance}'
        return message

def create_spend_chart(categories):
    print('Percentage spent by category')
    total_sum = 0
    sums = []

    for category in categories:
        spent = 0
        for transaction in category.ledger:
            if transaction['amount'] < 0:
                spent += -transaction['amount']  
        total_sum += spent
        sums.append(spent)
    
    percentages = []
    for spent in sums:
        percentage = round((spent / total_sum) * 100)
        percentages.append(percentage)
        print(percentage)
    for i in range (100,-1,-10):
        if i == 100:
            final = f'{i}|'
        elif i>0: 
            final = f' {i}|'
        else:
            final = f'  {i}|'
        
        for p in percentages:
            if p >= i:
                final += " o "
            else:
                final += "   "
            
            final += ' '
        print(final)

    dash = '-'*(len(categories))*3+'-'
    print('    '+dash)

    max_len = max(len(cat.name) for cat in categories)
    for i in range(max_len):
        line = "    "  # 5 spaces before vertical names
        for cat in categories:
            if i < len(cat.name):
                line += " " + cat.name[i] + " "
            else:
                line += "   "
            line +=' '
        print(line)

