class Category:
    def __init__(self,name):
        self.name = name
        self.ledger = []

    def deposit(self,amount,description):
        if not description:
            description = ''
        
        add = {'amount': amount, 'description': description}
        self.ledger.append(add)

    def withdraw(self,amount,description):
        if not self.check_funds(amount):
            return False

        else:
            if not description:
                description = ''
        
            remove = {'amount': -amount, 'description': description}
            self.ledger.append(remove)
            return True

    def get_balance(self):
        balance = 0
        for transaction in self.ledger:
            balance += transaction['amount']
        return balance

    def transfer(self, amount, Cat):
        if not self.check_funds(amount):
            return False
        self.withdraw(amount, f'Transfer to {Cat.name}')
        Cat.deposit(amount, f'Transfer from {self.name}')
        return True
    
    def check_funds(self,amount):
        balance = self.get_balance()
        if amount > balance:
            return False
        else:
            return True
    def __str__(self):
        balance=self.get_balance()
        header='*'*((30-len(self.name))//2)
        message = f'{header}{self.name}{header}\n'
        for transaction in self.ledger:     
            cut_description = transaction['description'][:23]
            part = f"{cut_description:<23}{transaction['amount']:>7.2f}"
            message += part + '\n'
        
        message += f'Total: {balance}'
        return message

